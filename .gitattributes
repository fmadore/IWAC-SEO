# Normalise line endings to LF in the repository (cross-platform consistency).
* text=auto eol=lf

# Binary assets — never normalise.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.mo   binary

# Exclude development cruft from `composer archive` / GitHub release tarballs.
/.gitattributes export-ignore
/.gitignore     export-ignore
